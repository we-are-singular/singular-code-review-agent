{
  "name": "singular-code-review-agent",
  "version": "0.2.0",
  "private": true,
  "description": "Production runner for Singular Code Review GitHub App reviews.",
  "type": "module",
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "npm run build && node --test test/*.test.js",
    "eval": "node eval/run.mjs"
  },
  "bin": {
    "review_runner": "dist/cli/review-runner.js",
    "review_extract": "dist/cli/review-extract.js",
    "review_comments": "dist/cli/review-comments.js",
    "review_context": "dist/cli/review-context.js",
    "review_guard": "dist/cli/review-guard.js",
    "review_ack": "dist/cli/review-ack.js",
    "review_dry_run": "bin/review_dry_run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
