{
  "name": "singular-code-review-agent",
  "version": "0.2.0",
  "private": true,
  "description": "Production runner for Singular Code Review GitHub App reviews.",
  "bin": {
    "review_ack": "dist/cli/review-ack.js",
    "review_comments": "dist/cli/review-comments.js",
    "review_context": "dist/cli/review-context.js",
    "review_dry_run": "bin/review_dry_run",
    "review_extract": "dist/cli/review-extract.js",
    "review_guard": "dist/cli/review-guard.js",
    "review_runner": "dist/cli/review-runner.js"
  },
  "type": "module",
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "npm run build && node --test test/*.test.js",
    "eval": "node eval/run.mjs",
    "eval:cache": "node eval/cache.mjs",
    "eval:judge": "node eval/judge.mjs",
    "eval:report": "node eval/report.mjs",
    "eval:benchmark": "node eval/benchmark.mjs",
    "lint": "tsc --noEmit && oxlint .",
    "lint:fix": "oxlint . --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  }
}
