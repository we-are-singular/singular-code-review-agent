#!/usr/bin/env node

const fs = require("node:fs");
const {
  addInlineComment,
  addReply,
  addSuggestion,
  setConclusion,
  clearQueue,
  contextFileFromEnv,
  loadQueue,
  queueFileFromEnv,
  readContext,
  saveQueue,
  validateQueue,
  writeJsonFile
} = require("../lib/review-tools");

function usage() {
  console.error(`usage:
  review_comments add --path <path> --line <line> [--start-line <line>] --body <body>
  review_comments suggest --path <path> --line <line> [--start-line <line>] --message <body> --replacement-file <file>
  review_comments reply --to <review-comment-id> --body <body>
  review_comments conclude --body <review-conclusion>
  review_comments list
  review_comments status
  review_comments validate [--context <file>] [--output <file>]
  review_comments clear`);
}

function fail(message) {
  console.error(`review_comments: ${message}`);
  process.exit(1);
}

function parseArgs(argv) {
  const result = { _: [] };

  for (let index = 0; index < argv.length; index += 1) {
    const arg = argv[index];
    if (!arg.startsWith("--")) {
      result._.push(arg);
      continue;
    }

    const key = arg.slice(2).replace(/-/g, "_");
    const next = argv[index + 1];
    if (!next || next.startsWith("--")) {
      result[key] = true;
    } else {
      result[key] = next;
      index += 1;
    }
  }

  return result;
}

function readBody(options, field = "body") {
  if (options[`${field}_file`]) {
    return fs.readFileSync(options[`${field}_file`], "utf8");
  }
  if (options[field]) {
    return options[field];
  }
  return options._.join(" ");
}

function printJson(value) {
  process.stdout.write(`${JSON.stringify(value, null, 2)}\n`);
}

function toReviewPayloadComment(comment) {
  const payload = {
    path: comment.path,
    line: comment.line,
    side: comment.side,
    body: comment.body
  };

  if (comment.start_line !== undefined) {
    payload.start_line = comment.start_line;
    payload.start_side = comment.start_side;
  }

  return payload;
}

function main() {
  const [command, ...rest] = process.argv.slice(2);
  const options = parseArgs(rest);
  const queueFile = options.queue || queueFileFromEnv();

  try {
    if (command === "add") {
      printJson(
        addInlineComment(
          {
            path: options.path,
            line: options.line,
            start_line: options.start_line,
            body: readBody(options),
            side: "RIGHT",
            start_side: "RIGHT"
          },
          queueFile
        )
      );
      return;
    }

    if (command === "suggest") {
      if (!options.replacement_file) {
        throw new Error("--replacement-file is required");
      }
      printJson(
        addSuggestion(
          {
            path: options.path,
            line: options.line,
            start_line: options.start_line,
            message: options.message || readBody(options, "message"),
            replacement: fs.readFileSync(options.replacement_file, "utf8"),
            side: "RIGHT",
            start_side: "RIGHT"
          },
          queueFile
        )
      );
      return;
    }

    if (command === "reply") {
      printJson(addReply({ to: options.to, body: readBody(options) }, queueFile));
      return;
    }

    if (command === "conclude") {
      printJson(setConclusion({ body: readBody(options) }, queueFile));
      return;
    }

    if (command === "list") {
      printJson(loadQueue(queueFile));
      return;
    }

    if (command === "clear") {
      printJson(clearQueue(queueFile));
      return;
    }

    if (command === "validate") {
      const context = readContext(options.context || contextFileFromEnv());
      const validated = validateQueue(loadQueue(queueFile), context);
      if (options.output) {
        writeJsonFile(options.output, validated);
      }
      const persisted = loadQueue(queueFile);
      persisted.dropped = validated.dropped;
      saveQueue(persisted, queueFile);
      printJson(validated);
      return;
    }

    if (command === "status") {
      const context = readContext(options.context || contextFileFromEnv());
      const queue = loadQueue(queueFile);
      const validated = validateQueue(queue, context);
      printJson({
        queue_file: queueFile,
        queued_inline: queue.inlineComments.length,
        queued_replies: queue.replies.length,
        has_conclusion: Boolean(validated.conclusion),
        valid_inline: validated.inlineComments.length,
        valid_replies: validated.replies.length,
        dropped: validated.dropped.length,
        submit_would_be_empty: validated.inlineComments.length === 0 && validated.replies.length === 0 && !validated.conclusion
      });
      return;
    }

    if (command === "payload-comments") {
      const context = readContext(options.context || contextFileFromEnv());
      printJson(validateQueue(loadQueue(queueFile), context).inlineComments.map(toReviewPayloadComment));
      return;
    }

    usage();
    fail("unknown or missing command");
  } catch (error) {
    fail(error.message || String(error));
  }
}

if (require.main === module) {
  main();
}
