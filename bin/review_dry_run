#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

usage() {
  cat >&2 <<'EOF'
usage:
  review_dry_run <owner/repo> <pr-number> [--workspace <path>] [--runtime-dir <path>] [--out-dir <path>]
  review_dry_run --repo <owner/repo> --pr <pr-number> [--workspace <path>] [--runtime-dir <path>] [--out-dir <path>]

Runs the Singular Code Review runner against a real GitHub pull request, but
sets DRY_RUN=true, bypasses the gate, and installs a read-only gh wrapper for
OpenCode investigation. The final review payload is printed by the runner and
kept under the runtime directory. By default artifacts are stored under
/tmp/.singular-code-review; pass --runtime-dir or SINGULAR_CODE_REVIEW_RUNTIME_DIR
to override the live runtime location. Pass --out-dir to copy the extracted
review_transcript.md, review_comments.json, and review_stats.json to a mounted
or persistent directory after the run.
EOF
}

log() {
  printf '[singular-code-review] %s\n' "$*" >&2
}

die() {
  log "error: $*"
  exit 1
}

require_tool() {
  command -v "$1" >/dev/null 2>&1 || die "required tool not found: $1"
}

slugify_repo() {
  printf '%s' "$1" | tr '/:' '--' | tr -cd '[:alnum:]._-' | tr '[:upper:]' '[:lower:]'
}

resolve_dist_dir() {
  if [[ -n "${SINGULAR_CODE_REVIEW_DIST_DIR:-}" ]]; then
    printf '%s\n' "$SINGULAR_CODE_REVIEW_DIST_DIR"
  elif [[ -f "${REPO_ROOT}/dist/cli/review-runner.js" ]]; then
    printf '%s\n' "${REPO_ROOT}/dist"
  else
    printf '%s\n' "/usr/local/lib/singular-code-review/dist"
  fi
}

parse_args() {
  repo=""
  pr_number=""
  workspace=""
  runtime_dir=""
  output_dir=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --repo)
        [[ "$#" -ge 2 ]] || die "--repo requires a value"
        repo="$2"
        shift 2
        ;;
      --pr)
        [[ "$#" -ge 2 ]] || die "--pr requires a value"
        pr_number="$2"
        shift 2
        ;;
      --workspace)
        [[ "$#" -ge 2 ]] || die "--workspace requires a value"
        workspace="$2"
        shift 2
        ;;
      --runtime-dir)
        [[ "$#" -ge 2 ]] || die "--runtime-dir requires a value"
        runtime_dir="$2"
        shift 2
        ;;
      --out-dir)
        [[ "$#" -ge 2 ]] || die "--out-dir requires a value"
        output_dir="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -z "$repo" ]]; then
          repo="$1"
        elif [[ -z "$pr_number" ]]; then
          pr_number="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$repo" ]] || die "repository is required"
  [[ "$repo" == */* ]] || die "repository must use owner/name format"
  [[ -n "$pr_number" ]] || die "pull request number is required"
  [[ "$pr_number" =~ ^[0-9]+$ ]] || die "pull request number must be numeric"
}

prepare_workspace() {
  local repo="$1"
  local pr_number="$2"
  local workspace="$3"
  local real_gh="$4"
  local github_token="$5"
  local dry_run_home="$6"

  if [[ -e "$workspace" ]]; then
    if [[ ! -d "$workspace" ]]; then
      die "workspace exists and is not a directory: $workspace"
    fi
    if [[ -n "$(find "$workspace" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
      die "workspace must be empty for a dry-run checkout: $workspace"
    fi
  fi

  mkdir -p "$(dirname "$workspace")"
  log "cloning ${repo} into ${workspace}"
  HOME="$dry_run_home" GH_TOKEN="$github_token" "$real_gh" repo clone "$repo" "$workspace" -- --filter=blob:none

  log "checking out pull request #${pr_number}"
  HOME="$dry_run_home" git \
    -c "url.https://x-access-token:${github_token}@github.com/.insteadOf=https://github.com/" \
    -C "$workspace" \
    fetch origin "pull/${pr_number}/head:refs/remotes/singular-code-review/pr-${pr_number}"
  HOME="$dry_run_home" git \
    -c "url.https://x-access-token:${github_token}@github.com/.insteadOf=https://github.com/" \
    -C "$workspace" \
    checkout --detach "refs/remotes/singular-code-review/pr-${pr_number}"
}

install_read_only_gh_wrapper() {
  local wrapper_dir="$1"

  mkdir -p "$wrapper_dir"
  cat > "${wrapper_dir}/gh" <<'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail

real_gh="${SINGULAR_CODE_REVIEW_REAL_GH:?}"

deny() {
  printf 'review_dry_run: blocked non-read-only gh command: gh %s\n' "$*" >&2
  exit 46
}

api_endpoint_and_method() {
  local method="GET"
  local endpoint=""
  local has_field="false"
  local skip_next="false"
  local arg
  local next

  local args=("$@")
  for ((index = 1; index < ${#args[@]}; index += 1)); do
    arg="${args[$index]}"

    if [[ "$skip_next" == "true" ]]; then
      skip_next="false"
      continue
    fi

    case "$arg" in
      -X|--method)
        next="${args[$((index + 1))]:-}"
        method="${next^^}"
        skip_next="true"
        continue
        ;;
      -f|-F|--field|--raw-field)
        has_field="true"
        skip_next="true"
        continue
        ;;
      -f=*|-F=*|--field=*|--raw-field=*)
        has_field="true"
        continue
        ;;
      -H|--header|--hostname|--jq|-q|--template|--input|--cache)
        skip_next="true"
        continue
        ;;
      --paginate|--slurp|--silent|--include|--verbose)
        continue
        ;;
      --*)
        continue
        ;;
      -*)
        continue
        ;;
      *)
        if [[ -z "$endpoint" ]]; then
          endpoint="$arg"
        fi
        ;;
    esac
  done

  if [[ "$endpoint" != "graphql" && "$method" == "GET" && "$has_field" == "true" ]]; then
    method="POST"
  fi

  printf '%s\n%s\n' "$endpoint" "$method"
}

if [[ "${1:-}" == "api" ]]; then
  mapfile -t parsed < <(api_endpoint_and_method "$@")
  endpoint="${parsed[0]:-}"
  method="${parsed[1]:-GET}"

  if [[ "$endpoint" == "graphql" ]]; then
    joined=" $* "
    if [[ "$joined" =~ [Mm][Uu][Tt][Aa][Tt][Ii][Oo][Nn] ]]; then
      deny "$@"
    fi
    exec "$real_gh" "$@"
  fi

  case "$method" in
    GET|HEAD)
      exec "$real_gh" "$@"
      ;;
    *)
      deny "$@"
      ;;
  esac
fi

case "${1:-}:${2:-}" in
  auth:*|repo:view|repo:clone|pr:view|pr:diff|pr:checks|pr:status|pr:list|issue:view|issue:list|run:view|run:list|search:*)
    exec "$real_gh" "$@"
    ;;
  *)
    deny "$@"
    ;;
esac
WRAPPER
  chmod +x "${wrapper_dir}/gh"
}

artifact_line() {
  local label="$1"
  local file="$2"

  if [[ -e "$file" ]]; then
    log "  ${label}: ${file}"
  else
    log "  ${label}: ${file} (missing)"
  fi
}

report_artifacts() {
  local runtime_dir="$1"

  log "dry-run artifacts:"
  artifact_line "review payload" "${runtime_dir}/review_payload.json"
  artifact_line "validated queue" "${runtime_dir}/review_validated.json"
  artifact_line "review model context" "${runtime_dir}/review_model_context.json"
  artifact_line "validation context" "${runtime_dir}/review_validation_context.json"
  artifact_line "review transcript" "${runtime_dir}/review_transcript.md"
  artifact_line "review comments" "${runtime_dir}/review_comments.json"
  artifact_line "review stats" "${runtime_dir}/review_stats.json"
  artifact_line "PR diff" "${runtime_dir}/pr.diff"
  artifact_line "reviewer output" "${runtime_dir}/opencode_review.log"
  artifact_line "audit output" "${runtime_dir}/opencode_audit.log"
  artifact_line "synthesis output" "${runtime_dir}/opencode_synthesis.log"
}

run_extractor() {
  local runtime_dir="$1"
  local wrapper_dir="$2"
  local dry_run_home="$3"
  local dry_run_config_home="$4"
  local dry_run_data_home="$5"
  local dry_run_cache_home="$6"
  local dry_run_state_home="$7"

  log "extracting review outputs and telemetry"
  PATH="${wrapper_dir}:${PATH}" \
    HOME="$dry_run_home" \
    XDG_CONFIG_HOME="$dry_run_config_home" \
    XDG_DATA_HOME="$dry_run_data_home" \
    XDG_CACHE_HOME="$dry_run_cache_home" \
    XDG_STATE_HOME="$dry_run_state_home" \
    WORKSPACE="$workspace" \
    GITHUB_REPOSITORY="$repo" \
    PR_NUMBER="$pr_number" \
    OPENCODE_MODEL="${OPENCODE_MODEL:-opencode-go/minimax-m2.7}" \
    SINGULAR_CODE_REVIEW_RUNTIME_DIR="$runtime_dir" \
    review_extract --runtime-dir "$runtime_dir" >/dev/null
}

export_extracted_outputs() {
  local runtime_dir="$1"
  local output_dir="$2"

  [[ -n "$output_dir" ]] || return 0
  mkdir -p "$output_dir"
  cp -f \
    "${runtime_dir}/review_transcript.md" \
    "${runtime_dir}/review_comments.json" \
    "${runtime_dir}/review_stats.json" \
    "$output_dir"
  log "copied extracted outputs to ${output_dir}"
}

install_node_commands() {
  local wrapper_dir="$1"
  local dist_dir
  dist_dir="$(resolve_dist_dir)"

  local commands=(
    "review_ack:review-ack.js"
    "review_comments:review-comments.js"
    "review_context:review-context.js"
    "review_extract:review-extract.js"
    "review_guard:review-guard.js"
    "review_runner:review-runner.js"
  )

  local entry
  local command
  local script
  local target
  for entry in "${commands[@]}"; do
    command="${entry%%:*}"
    script="${entry#*:}"
    target="${dist_dir}/cli/${script}"
    [[ -f "$target" ]] || die "built CLI entrypoint not found: $target; run npm run build first"
    [[ -x "$target" ]] || chmod +x "$target"
    ln -sf "$target" "${wrapper_dir}/${command}"
  done
}

main() {
  parse_args "$@"
  require_tool gh
  require_tool git

  local real_gh
  real_gh="$(command -v gh)"

  "$real_gh" auth status >/dev/null 2>&1 || die "gh auth status failed; authenticate with gh before running a dry run"
  [[ -n "${OPENCODE_API_KEY:-}" ]] || die "OPENCODE_API_KEY is required for the OpenCode review pass"
  local github_token
  github_token="${GH_TOKEN:-$("$real_gh" auth token)}"

  local slug
  slug="$(slugify_repo "$repo")"

  if [[ -z "$workspace" ]]; then
    workspace="${TMPDIR:-/tmp}/singular-code-review-dry-run/${slug}-pr-${pr_number}-$(date +%Y%m%d%H%M%S)"
  fi

  if [[ -z "$runtime_dir" ]]; then
    runtime_dir="${SINGULAR_CODE_REVIEW_RUNTIME_DIR:-}"
  fi
  if [[ -z "$runtime_dir" ]]; then
    runtime_dir="${TMPDIR:-/tmp}/.singular-code-review/${slug}-pr-${pr_number}-$(date +%Y%m%d%H%M%S)"
  fi

  local wrapper_dir="${runtime_dir}/dry-run-bin"
  local provision="${REVIEW_PROVISION:-${REPO_ROOT}/bin/provision.sh}"
  if [[ ! -x "$provision" && -x "/usr/local/bin/provision.sh" ]]; then
    provision="/usr/local/bin/provision.sh"
  fi
  local runner="${REVIEW_RUNNER:-${wrapper_dir}/review_runner}"
  local dry_run_home="${runtime_dir}/home"
  local dry_run_config_home="${runtime_dir}/xdg/config"
  local dry_run_data_home="${runtime_dir}/xdg/data"
  local dry_run_cache_home="${runtime_dir}/xdg/cache"
  local dry_run_state_home="${runtime_dir}/xdg/state"
  mkdir -p \
    "$runtime_dir" \
    "$dry_run_home" \
    "$dry_run_config_home" \
    "$dry_run_data_home" \
    "$dry_run_cache_home" \
    "$dry_run_state_home"

  prepare_workspace "$repo" "$pr_number" "$workspace" "$real_gh" "$github_token" "$dry_run_home"

  install_read_only_gh_wrapper "$wrapper_dir"
  install_node_commands "$wrapper_dir"

  log "dry-run workspace: $workspace"
  log "dry-run runtime dir: $runtime_dir"
  log "running reviewer without GitHub writes"

  set +e
  log "running provision step"
  PATH="${wrapper_dir}:${PATH}" \
    HOME="$dry_run_home" \
    XDG_CONFIG_HOME="$dry_run_config_home" \
    XDG_DATA_HOME="$dry_run_data_home" \
    XDG_CACHE_HOME="$dry_run_cache_home" \
    XDG_STATE_HOME="$dry_run_state_home" \
    SINGULAR_CODE_REVIEW_REAL_GH="$real_gh" \
    WORKSPACE="$workspace" \
    GITHUB_REPOSITORY="$repo" \
    PR_NUMBER="$pr_number" \
    GH_TOKEN="$github_token" \
    DRY_RUN=true \
    SINGULAR_CODE_REVIEW_RUNTIME_DIR="$runtime_dir" \
    "$provision"
  local provision_status=$?
  local status="$provision_status"
  if [[ "$provision_status" -eq 0 ]]; then
    log "provision step finished"
    log "running review runner"
    PATH="${wrapper_dir}:${PATH}" \
      HOME="$dry_run_home" \
      XDG_CONFIG_HOME="$dry_run_config_home" \
      XDG_DATA_HOME="$dry_run_data_home" \
      XDG_CACHE_HOME="$dry_run_cache_home" \
      XDG_STATE_HOME="$dry_run_state_home" \
      SINGULAR_CODE_REVIEW_REAL_GH="$real_gh" \
      WORKSPACE="$workspace" \
      GITHUB_REPOSITORY="$repo" \
      PR_NUMBER="$pr_number" \
      GH_TOKEN="$github_token" \
      DRY_RUN=true \
      SINGULAR_CODE_REVIEW_RUNTIME_DIR="$runtime_dir" \
      "$runner"
    status=$?
    if [[ "$status" -eq 0 ]]; then
      log "review runner finished"
    else
      log "review runner failed with status $status"
    fi
  else
    log "provision step failed with status $provision_status; review runner was not started"
  fi
  set -e

  set +e
  run_extractor \
    "$runtime_dir" \
    "$wrapper_dir" \
    "$dry_run_home" \
    "$dry_run_config_home" \
    "$dry_run_data_home" \
    "$dry_run_cache_home" \
    "$dry_run_state_home"
  local extract_status=$?
  if [[ "$extract_status" -eq 0 ]]; then
    export_extracted_outputs "$runtime_dir" "$output_dir"
    extract_status=$?
  fi
  set -e

  if [[ "$extract_status" -eq 0 ]]; then
    log "review extraction finished"
  else
    log "review extraction failed with status $extract_status"
    if [[ "$status" -eq 0 ]]; then
      status="$extract_status"
    fi
  fi

  report_artifacts "$runtime_dir"

  exit "$status"
}

main "$@"
