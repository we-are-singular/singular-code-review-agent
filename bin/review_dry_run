#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

usage() {
  cat >&2 <<'EOF'
usage:
  review_dry_run <owner/repo> <pr-number> [--workspace <path>]
  review_dry_run --repo <owner/repo> --pr <pr-number> [--workspace <path>]

Runs the real Singular Code Review orchestrator against a real GitHub pull
request, but sets DRY_RUN=true and installs a read-only gh wrapper for the
review process. The final review payload is printed by the orchestrator and
kept under the checkout's .git/singular-code-review directory.
EOF
}

log() {
  printf '[singular-code-review] %s\n' "$*" >&2
}

die() {
  log "error: $*"
  exit 1
}

require_tool() {
  command -v "$1" >/dev/null 2>&1 || die "required tool not found: $1"
}

slugify_repo() {
  printf '%s' "$1" | tr '/:' '--' | tr -cd '[:alnum:]._-' | tr '[:upper:]' '[:lower:]'
}

parse_args() {
  repo=""
  pr_number=""
  workspace=""

  while [[ "$#" -gt 0 ]]; do
    case "$1" in
      --repo)
        [[ "$#" -ge 2 ]] || die "--repo requires a value"
        repo="$2"
        shift 2
        ;;
      --pr)
        [[ "$#" -ge 2 ]] || die "--pr requires a value"
        pr_number="$2"
        shift 2
        ;;
      --workspace)
        [[ "$#" -ge 2 ]] || die "--workspace requires a value"
        workspace="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      --*)
        die "unknown option: $1"
        ;;
      *)
        if [[ -z "$repo" ]]; then
          repo="$1"
        elif [[ -z "$pr_number" ]]; then
          pr_number="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -n "$repo" ]] || die "repository is required"
  [[ "$repo" == */* ]] || die "repository must use owner/name format"
  [[ -n "$pr_number" ]] || die "pull request number is required"
  [[ "$pr_number" =~ ^[0-9]+$ ]] || die "pull request number must be numeric"
}

prepare_workspace() {
  local repo="$1"
  local pr_number="$2"
  local workspace="$3"
  local real_gh="$4"

  if [[ -e "$workspace" ]]; then
    if [[ ! -d "$workspace" ]]; then
      die "workspace exists and is not a directory: $workspace"
    fi
    if [[ -n "$(find "$workspace" -mindepth 1 -maxdepth 1 -print -quit)" ]]; then
      die "workspace must be empty for a dry-run checkout: $workspace"
    fi
  fi

  mkdir -p "$(dirname "$workspace")"
  log "cloning ${repo} into ${workspace}"
  "$real_gh" repo clone "$repo" "$workspace" -- --filter=blob:none

  log "checking out pull request #${pr_number}"
  git -C "$workspace" fetch origin "pull/${pr_number}/head:refs/remotes/singular-code-review/pr-${pr_number}"
  git -C "$workspace" checkout --detach "refs/remotes/singular-code-review/pr-${pr_number}"
}

install_read_only_gh_wrapper() {
  local wrapper_dir="$1"

  mkdir -p "$wrapper_dir"
  cat > "${wrapper_dir}/gh" <<'WRAPPER'
#!/usr/bin/env bash
set -euo pipefail

real_gh="${SINGULAR_CODE_REVIEW_REAL_GH:?}"

deny() {
  printf 'review_dry_run: blocked non-read-only gh command: gh %s\n' "$*" >&2
  exit 46
}

api_endpoint_and_method() {
  local method="GET"
  local endpoint=""
  local has_field="false"
  local skip_next="false"
  local arg
  local next

  local args=("$@")
  for ((index = 1; index < ${#args[@]}; index += 1)); do
    arg="${args[$index]}"

    if [[ "$skip_next" == "true" ]]; then
      skip_next="false"
      continue
    fi

    case "$arg" in
      -X|--method)
        next="${args[$((index + 1))]:-}"
        method="${next^^}"
        skip_next="true"
        continue
        ;;
      -f|-F|--field|--raw-field)
        has_field="true"
        skip_next="true"
        continue
        ;;
      -f=*|-F=*|--field=*|--raw-field=*)
        has_field="true"
        continue
        ;;
      -H|--header|--hostname|--jq|-q|--template|--input|--cache)
        skip_next="true"
        continue
        ;;
      --paginate|--slurp|--silent|--include|--verbose)
        continue
        ;;
      --*)
        continue
        ;;
      -*)
        continue
        ;;
      *)
        if [[ -z "$endpoint" ]]; then
          endpoint="$arg"
        fi
        ;;
    esac
  done

  if [[ "$endpoint" != "graphql" && "$method" == "GET" && "$has_field" == "true" ]]; then
    method="POST"
  fi

  printf '%s\n%s\n' "$endpoint" "$method"
}

if [[ "${1:-}" == "api" ]]; then
  mapfile -t parsed < <(api_endpoint_and_method "$@")
  endpoint="${parsed[0]:-}"
  method="${parsed[1]:-GET}"

  if [[ "$endpoint" == "graphql" ]]; then
    joined=" $* "
    if [[ "$joined" =~ [Mm][Uu][Tt][Aa][Tt][Ii][Oo][Nn] ]]; then
      deny "$@"
    fi
    exec "$real_gh" "$@"
  fi

  case "$method" in
    GET|HEAD)
      exec "$real_gh" "$@"
      ;;
    *)
      deny "$@"
      ;;
  esac
fi

case "${1:-}:${2:-}" in
  auth:*|repo:view|repo:clone|pr:view|pr:diff|pr:checks|pr:status|pr:list|issue:view|issue:list|run:view|run:list|search:*)
    exec "$real_gh" "$@"
    ;;
  *)
    deny "$@"
    ;;
esac
WRAPPER
  chmod +x "${wrapper_dir}/gh"
}

main() {
  parse_args "$@"
  require_tool gh
  require_tool git

  local real_gh
  real_gh="$(command -v gh)"

  "$real_gh" auth status >/dev/null 2>&1 || die "gh auth status failed; authenticate with gh before running a dry run"
  [[ -n "${OPENCODE_API_KEY:-}" ]] || die "OPENCODE_API_KEY is required for the OpenCode review pass"

  if [[ -z "$workspace" ]]; then
    local slug
    slug="$(slugify_repo "$repo")"
    workspace="${TMPDIR:-/tmp}/singular-code-review-dry-run/${slug}-pr-${pr_number}-$(date +%Y%m%d%H%M%S)"
  fi

  prepare_workspace "$repo" "$pr_number" "$workspace" "$real_gh"

  local runtime_dir="${workspace}/.git/singular-code-review"
  local wrapper_dir="${runtime_dir}/dry-run-bin"
  local orchestrator="${REVIEW_ORCHESTRATOR:-${REPO_ROOT}/bin/review_orchestrator.sh}"
  mkdir -p "$runtime_dir"
  install_read_only_gh_wrapper "$wrapper_dir"

  log "dry-run workspace: $workspace"
  log "dry-run runtime dir: $runtime_dir"
  log "running orchestrator without GitHub writes"

  set +e
  PATH="${wrapper_dir}:${REPO_ROOT}/bin:${PATH}" \
    SINGULAR_CODE_REVIEW_REAL_GH="$real_gh" \
    WORKSPACE="$workspace" \
    GITHUB_REPOSITORY="$repo" \
    PR_NUMBER="$pr_number" \
    DRY_RUN=true \
    "$orchestrator"
  local status=$?
  set -e

  log "dry-run artifacts:"
  log "  final review payload: ${runtime_dir}/final_review.json"
  log "  validated queue: ${runtime_dir}/review_validated.json"
  log "  review context: ${runtime_dir}/review_context.json"
  log "  PR diff: ${runtime_dir}/pr.diff"
  log "  reviewer output: ${runtime_dir}/opencode_review_output.log"
  log "  audit output: ${runtime_dir}/opencode_review_audit.log"
  log "  synthesis output: ${runtime_dir}/opencode_review_conclusion.log"

  exit "$status"
}

main "$@"
